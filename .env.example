# --- Database (PostGIS via docker-compose) ---
DATABASE_URL=postgresql+psycopg2://aq:aq@localhost:5432/aqdb

# --- Ingestion source ---
# "mock" (default, deterministic, offline) | "live" (real CPCB CAAQMS adapter)
AQ_SOURCE=mock
CPCB_API_BASE=https://app.cpcbccr.com/aqi_dashboard

# --- Target station defaults (used by seed) ---
TZ=Asia/Kolkata
