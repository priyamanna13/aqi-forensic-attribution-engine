# Copy this file to ".env" and adjust as needed.
#   copy .env.example .env        (Windows cmd)
#   cp .env.example .env          (Linux/macOS)
#
# These defaults match docker-compose.yml, so a plain `copy` works out of the box.

POSTGRES_USER=aqi
POSTGRES_PASSWORD=aqi_pass
POSTGRES_DB=aqi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: set to 1 to echo all SQL emitted by SQLAlchemy (verbose, dev only).
DB_ECHO=0

# ML Model URL for connection
ML_MODEL_URL=http://localhost:8000


# Task 2 — OpenWeatherMap API key for the weather client.
# The pipeline degrades gracefully (uses api_cache/) when this is missing or
# the network is unavailable, so a blank value still works for offline tests.
# Get a free key at https://openweathermap.org/api.
OWM_API_KEY=
OWM_API_TIMEOUT=10
